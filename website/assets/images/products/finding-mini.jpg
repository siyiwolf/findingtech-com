<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="miniGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2ECC71;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0057B8;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="#f5f5f5"/>
  <!-- Mini device - circular/oval -->
  <ellipse cx="200" cy="130" rx="60" ry="80" fill="url(#miniGrad)"/>
  <circle cx="200" cy="110" r="15" fill="none" stroke="white" stroke-width="3"/>
  <line x1="200" y1="125" x2="200" y2="145" stroke="white" stroke-width="2" stroke-linecap="round"/>
  <text x="200" y="200" font-family="Inter, sans-serif" font-size="16" fill="white" text-anchor="middle" font-weight="600">SOS</text>
  <text x="200" y="240" font-family="Inter, sans-serif" font-size="18" font-weight="600" fill="#0057B8" text-anchor="middle">
    Finding Mini
  </text>
</svg>